  "glossary": [
    {
      "term": "right-sided quaternion Fourier transform",
      "definition": "A DQFT convention where the exponential kernel multiplies each quaternion sample on the right.",
      "aliases": ["right-kernel DQFT"],
      "paper_specific": true,
      "related_terms": ["fixed-axis transform", "kernel placement"],
      "see_also": ["commuting slice"]
    },
    {
      "term": "fixed-axis transform",
      "definition": "A transform convention that uses a single declared imaginary axis (here i) for all kernel phases.",
      "aliases": ["axis-fixed DQFT"],
      "paper_specific": true,
      "related_terms": ["right-sided quaternion Fourier transform", "commuting slice"],
      "see_also": []
    },
    {
      "term": "commuting slice",
      "definition": "The subalgebra C_i={a+b i} inside H in which kernel exponentials commute.",
      "aliases": ["C_i slice"],
      "paper_specific": true,
      "related_terms": ["fixed-axis transform", "right C_i-linearity"],
